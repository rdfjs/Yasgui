{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "removeComments": true,
    "sourceMap": true,
    "listFiles": false,
    "outDir": "./build/ts",
    "rootDir": ".",
    "paths": {
      "@zazuko/yasgui": ["./packages/yasgui/src"],
      "@zazuko/yasgui-utils": ["./packages/utils/src"],
      "@zazuko/yasqe": ["./packages/yasqe/src"],
      "@zazuko/yasqe-codemirror": ["./packages/yasqe-codemirror/src"],
      "@zazuko/yasr": ["./packages/yasr/src"]
    }
  },
  "files": ["./packages/yasgui/typings-custom/main.d.ts", "./vite-env.d.ts"],
  "include": ["./packages/*/src/**/**/*", "./test/*"],
  "compileOnSave": false,
  "exclude": ["**/build/**"]
}
